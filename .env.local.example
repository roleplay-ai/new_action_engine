# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: email that always gets superadmin role (default: admin@actionengine)
# SUPERADMIN_EMAIL=admin@actionengine

# Required for superadmin user creation (Phase 2b)
# Get this from Supabase Dashboard > Settings > API > service_role key
# WARNING: Keep this secret! Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


RESEND_API_KEY=re_xxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
NEXT_PUBLIC_APP_URL=https://nudgeable-action-engine.vercel.app

# Get an API key at https://aistudio.google.com/apikey
# Used to generate personal actions from the user's training answers (Gemini Flash),
# including the background batch job that fills out a full multi-week plan.
GEMINI_API_KEY=xxxxxx

# Optional: also protects app/api/generate-actions-batch (the background action-plan
# generator) in addition to the cron endpoint. Vercel sets this automatically when
# the env var is present; for local testing pass ?secret= or an Authorization header.
# CRON_SECRET=xxxxxx